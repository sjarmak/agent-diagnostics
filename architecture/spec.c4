// Element kinds, tags, and custom colors for the `agent-diagnostics`
// (Agent Reliability Observatory) architecture model.
//
// Tags encode delivery state so evolving / planned / research work is visually
// distinct from what is already built and exercised:
//   #built     — code path exists and is exercised by tests / the shipped run
//   #evolving  — built, but the contract or science is still moving (taxonomy
//                versions, calibration semantics, blend trust policy)
//   #planned   — designed / documented, not yet implemented (or v1 is a stub)
//   #research  — speculative research track (docs/design PRDs)

specification {

  element actor {
    style {
      shape person
      color secondary
    }
  }

  element externalSystem {
    style {
      shape rectangle
      color slate
    }
  }

  element system

  element container {
    style {
      shape rectangle
    }
  }

  element component

  element datastore {
    style {
      shape cylinder
    }
  }

  // Deployment model — where each piece runs at review time.
  deploymentNode host {
    style {
      shape rectangle
      color slate
    }
  }
  deploymentNode proc

  tag built {
    color #16a34a
  }
  tag evolving {
    color #d97706
  }
  tag planned {
    color #64748b
  }
  tag research {
    color #6366f1
  }

  // Cross-cutting: carried by any element that is a known risk / open question
  // for the design review (in addition to its delivery-state tag).
  tag risk {
    color #dc2626
  }
}
