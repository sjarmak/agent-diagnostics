{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "observatory-export-manifest-v1",
  "title": "Observatory Export Manifest",
  "description": "Schema for the MANIFEST.json produced by observatory export.",
  "type": "object",
  "required": [
    "schema_version",
    "taxonomy_version",
    "row_count",
    "sha256_per_file",
    "source_commit",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version of the source signals data."
    },
    "taxonomy_version": {
      "type": "string",
      "description": "Taxonomy version used for annotations."
    },
    "row_count": {
      "type": "object",
      "description": "Row counts per exported file.",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "sha256_per_file": {
      "type": "object",
      "description": "SHA-256 hex digests per exported file.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "source_commit": {
      "type": "string",
      "description": "Git commit hash at time of export."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the export was generated."
    }
  },
  "additionalProperties": false
}
