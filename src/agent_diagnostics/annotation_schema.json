{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "observatory-annotation-v1",
  "title": "Observatory Annotation",
  "description": "Schema for Agent Reliability Observatory annotations — structured reliability findings attached to benchmark trials.",
  "type": "object",
  "required": ["schema_version", "annotations"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "observatory-annotation-v1",
      "description": "Schema version identifier."
    },
    "taxonomy_version": {
      "type": "string",
      "description": "Version of the taxonomy used for category names (e.g. '1.0')."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this annotation file was generated."
    },
    "annotator": {
      "$ref": "#/$defs/annotator",
      "description": "Default annotator for all annotations in this file (can be overridden per annotation)."
    },
    "annotations": {
      "type": "array",
      "description": "List of per-trial annotations.",
      "items": {
        "$ref": "#/$defs/annotation"
      }
    },
    "blend_metadata": {
      "type": "object",
      "description": "Metadata emitted by the blended annotator (source mix, trust thresholds, trusted-heuristic categories, etc.).",
      "additionalProperties": true
    },
    "migration": {
      "type": "array",
      "description": "Audit trail of taxonomy-version migrations applied to this file.",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {
            "type": "string",
            "description": "Source taxonomy version."
          },
          "to": { "type": "string", "description": "Target taxonomy version." },
          "tool": {
            "type": "string",
            "description": "Migration tool identifier."
          },
          "applied_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when migration ran."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "annotation": {
      "type": "object",
      "required": ["task_id", "trial_path", "reward", "passed", "categories"],
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Unique task identifier (e.g. 'swe-bench-lite-001')."
        },
        "trial_path": {
          "type": "string",
          "description": "Relative path to the trial directory from the repo root."
        },
        "reward": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Final verifier reward (0-1)."
        },
        "passed": {
          "type": "boolean",
          "description": "Whether the trial passed (reward > 0)."
        },
        "categories": {
          "type": "array",
          "description": "Taxonomy categories assigned to this trial.",
          "items": {
            "$ref": "#/$defs/category_assignment"
          }
        },
        "run_id": {
          "type": "string",
          "description": "Run identifier from the manifest."
        },
        "model": {
          "type": "string",
          "description": "Model used for the trial (e.g. 'claude-sonnet-4-6')."
        },
        "config_name": {
          "type": "string",
          "description": "Harness configuration name (e.g. 'baseline', 'sourcegraph_full')."
        },
        "benchmark": {
          "type": "string",
          "description": "Benchmark suite name (e.g. 'swebench_lite', 'locobench')."
        },
        "annotator": {
          "$ref": "#/$defs/annotator",
          "description": "Annotator for this specific annotation (overrides file-level annotator)."
        },
        "notes": {
          "type": "string",
          "description": "Freeform analyst commentary."
        },
        "signals": {
          "type": "object",
          "description": "Raw signal values used to derive annotations.",
          "additionalProperties": true
        },
        "annotated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when this annotation was created."
        }
      },
      "additionalProperties": false
    },
    "category_assignment": {
      "type": "object",
      "required": ["name", "confidence"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Taxonomy category short name (must match a name in the taxonomy)."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in this assignment (0-1)."
        },
        "evidence": {
          "type": "string",
          "description": "Pointer to trace step, tool call, or transcript line supporting the assignment."
        },
        "source": {
          "type": "string",
          "enum": [
            "llm",
            "heuristic",
            "heuristic_trusted",
            "classifier",
            "manual"
          ],
          "description": "Provenance of this category assignment. Set by the blended annotator to record which upstream producer emitted the label."
        },
        "calibration_status": {
          "type": "string",
          "enum": ["calibrated", "pending"],
          "description": "Whether this category assignment has been calibrated. Used by csb diagnose to mark uncalibrated categories."
        }
      },
      "additionalProperties": false
    },
    "annotator": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "manual",
            "heuristic",
            "llm",
            "classifier",
            "ensemble",
            "blended"
          ],
          "description": "How the annotation was produced."
        },
        "identity": {
          "type": "string",
          "description": "Identifier of the annotator (person, script name, model name)."
        }
      },
      "additionalProperties": false
    }
  }
}
